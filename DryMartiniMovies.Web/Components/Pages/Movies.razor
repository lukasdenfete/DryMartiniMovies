@page "/movies"
@rendermode InteractiveServer
@inject MovieApiService MovieApiService
@inject NavigationManager Navigation


<h1>Mina filmer 🍸</h1>

<MovieSearch Genres="genres" OnSearchChanged="HandleSearch"/>
<ErrorMessage Message="@errorMessage" />

@if (movies == null && errorMessage == null)
{
    <div class="d-flex align-items-center gap-3">
        <div class="spinner-border text-primary" role="status"></div>
        <p class="mb-0">Laddar filmer...</p>
    </div>
}
else
{
    <div class="movie-grid">
        @foreach (var userMovie in filteredMovies)
        {
            <div class="movie-card" @onclick="() => NavigateToMovie(userMovie.Movie!.TmdbId)">
                <img src="@($"https://image.tmdb.org/t/p/w200{userMovie.Movie?.PosterPath}")" 
                     alt="@userMovie.Movie?.Title" />
                <div class="movie-info">
                    <h6>@userMovie.Movie?.Title</h6>
                    <small>@userMovie.Movie?.Year</small>
                    <div class="rating">⭐ @userMovie.Rating / 5</div>
                </div>
            </div>
        }
    </div>
}

<style>
    .movie-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
        gap: 1rem;
        padding: 1rem 0;
    }

    .movie-card {
        background: #1a1a2e;
        border-radius: 8px;
        overflow: hidden;
        transition: transform 0.2s;
        cursor: pointer;
        display: flex;
        flex-direction: column;
    }

    .movie-card:hover {
        transform: scale(1.03);
    }

    .movie-card img {
        width: 100%;
        display: block;
    }

    .movie-info {
        padding: 0.5rem;
        color: white;
        flex: 1;
        display: flex;
        flex-direction: column;
    }

    .movie-info h6 {
        margin: 0 0 0.25rem 0;
        font-size: 0.85rem;
        word-wrap: break-word;
        overflow-wrap: break-word;
    }

    .movie-info small {
        color: #aaa;
    }

    .rating {
        font-size: 0.8rem;
        margin-top: auto;
        padding-top: 0.25rem;
    }
</style>

@code {
    private List<UserMovie>? movies;
    private List<UserMovie> filteredMovies = new ();
    private List<string> genres = new ();
    private string? errorMessage;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            movies = await MovieApiService.GetUserMoviesAsync();
            
            genres = movies
                .Where(m => m.Movie?.Genres != null)
                .SelectMany(m => m.Movie!.Genres)
                .Select(g => g.Name)
                .Distinct()
                .OrderBy(g => g)
                .ToList();

            filteredMovies = movies;
        }
        catch (Exception)
        {
            errorMessage = "Kunde inte hämta filmer. Kolla så API:et är igång.";
        }
    }
    private void HandleSearch((string query, string genre, string sort) args)
    {
        if (movies == null) return;

        filteredMovies = movies.Where(m =>
        {
            var matchesQuery = string.IsNullOrEmpty(args.query) ||
                m.Movie!.Title.Contains(args.query, StringComparison.OrdinalIgnoreCase);

            var matchesGenre = string.IsNullOrEmpty(args.genre) ||
                m.Movie!.Genres.Any(g => g.Name == args.genre);

            return matchesQuery && matchesGenre;
        }).ToList();

        filteredMovies = args.sort switch
        {
            "asc" => filteredMovies.OrderBy(m => m.Rating).ToList(),
            "desc" => filteredMovies.OrderByDescending(m => m.Rating).ToList(),
            _ => filteredMovies // ingen sortering
        };
    }
    private void NavigateToMovie(int tmdbId) {
        Navigation.NavigateTo($"/movies/{tmdbId}?from=/movies");
    }

}