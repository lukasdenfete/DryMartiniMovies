@page "/recent"
@rendermode InteractiveServer
@inject MovieApiService MovieApiService
@inject NavigationManager Navigation

<h3 class="section-title">Nyligen sett</h3>
<ErrorMessage Message="@errorMessage"/>

@if (recentMovies == null && errorMessage == null){
    <div class="d-flex align-items-center gap-3">
        <div class="spinner-border text-primary" role="status"></div>
        <p class="mb-0">Laddar filmer...</p>
    </div>
}
else if (recentMovies != null) {
<div class="movie-grid">
@foreach (var movie in recentMovies){
    <div class="movie-card" @onclick="() => NavigateToMovie(movie.TmdbId)">
        <img src="@($"https://image.tmdb.org/t/p/w300{@movie.PosterPath}")" alt="@movie.Title"/>
        <div class="movie-info">
            <h6>@movie.Title</h6>
            <div class="rating">Ditt betyg: @movie.UserRating /5</div>
            <small>Såg den: @movie.WatchedDate?.ToString("yyyy-MM-dd")</small>
        </div>
    </div>
}
</div>

}
<style>
    .section-title {
        color: #ccc;
        font-size: 1.4rem;
        font-weight: 600;
        letter-spacing: normal;
        text-transform: none;
        margin-bottom: 0.5rem;
    }
    .movie-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
        gap: 1rem;
        padding: 1rem 0;
    }

    .movie-card {
        background: #1a1a2e;
        border-radius: 8px;
        overflow: hidden;
        transition: transform 0.2s;
        cursor: pointer;
        display: flex;
        flex-direction: column;
    }

    .movie-card:hover {
        transform: scale(1.03);
    }

    .movie-card img {
        width: 100%;
        display: block;
    }

    .movie-info {
        padding: 0.5rem;
        color: white;
        flex: 1;
        display: flex;
        flex-direction: column;
    }

    .movie-info h6 {
        margin: 0 0 0.25rem 0;
        font-size: 0.85rem;
        word-wrap: break-word;
        overflow-wrap: break-word;
    }

    .movie-info small {
        color: #aaa;
    }

    .rating {
        font-size: 0.8rem;
        margin-top: auto;
        padding-top: 0.25rem;
    }
</style>

@code {
    private List<MovieDto>? recentMovies;
    private string? errorMessage;

    protected override async Task OnInitializedAsync(){
        try {
            recentMovies = await MovieApiService.GetRecentMoviesAsync();

        }
        catch (Exception){
            errorMessage = "Kunde inte hämta filmer. Kolla så API:et är igång.";
        }

    }
        private void NavigateToMovie(int tmdbId) {
        Navigation.NavigateTo($"/movies/{tmdbId}?from=/");
    }
}