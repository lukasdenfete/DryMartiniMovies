@page "/add"
@using DryMartiniMovies.Client.Services;
@inject MovieApiService MovieApiService
@inject NavigationManager NavigationManager
@rendermode InteractiveServer

<div class="add-page">
    <h1 class="page-title">Lägg till film 🍸</h1>

    <div class="search-card">
        <form @onsubmit="HandleSearchMovie">
            <div class="row g-2 align-items-end">
                <div class="col-12 col-sm">
                    <label class="form-label">Titel</label>
                    <input class="form-control dark-input" type="text" @bind="title" placeholder="t.ex. Dune" />
                </div>
                <div class="col-6 col-sm-auto">
                    <label class="form-label">År</label>
                    <input class="form-control dark-input year-input" type="number" @bind="year" placeholder="2024" />
                </div>
                <div class="col-6 col-sm-auto">
                    <button class="btn btn-primary w-100" type="submit">Sök</button>
                </div>
            </div>
        </form>
    </div>

    @if (movie != null)
    {
        <div class="result-card">
            <div class="result-poster-wrap">
                <img src="@($"https://image.tmdb.org/t/p/w300{movie.PosterPath}")" alt="@movie.Title" class="result-poster" />
            </div>
            <div class="result-info">
                <h4 class="result-title">@movie.Title</h4>
                <p class="result-year">@movie.Year</p>
                <p class="result-desc">@movie.Description</p>
                <div class="result-credits">
                    @foreach (var director in movie.Directors)
                    {
                        <span class="credit-badge director">Regissör: @director</span>
                    }
                </div>
                <div class="result-credits actors-row">
                    @foreach (var actor in movie.Actors)
                    {
                        <span class="credit-badge actor">@actor</span>
                    }
                </div>

                @if (!isRight)
                {
                    <div class="confirm-section">
                        <p class="confirm-label">Menar du denna film?</p>
                        <div class="d-flex gap-2">
                            <button class="btn btn-success" type="button" @onclick="() => isRight = true">Ja, det stämmer</button>
                            <button class="btn btn-outline-secondary" type="button" @onclick="HandleNo">Nej, sök igen</button>
                        </div>
                    </div>
                }
                else
                {
                    <div class="rating-form">
                        <div class="row g-3">
                            <div class="col-12 col-sm-4">
                                <label class="form-label">Ditt betyg</label>
                                <input class="form-control dark-input" type="number" step="0.5" min="0" max="10" @bind="userRating" placeholder="0–10" />
                            </div>
                            <div class="col-12 col-sm-8">
                                <label class="form-label">Sett datum</label>
                                <input class="form-control dark-input" type="date" @bind="watchedDate" />
                            </div>
                        </div>
                        <div class="mt-3">
                            <button class="btn btn-primary" type="button" @onclick="HandleSaveMovie">Lägg till film</button>
                        </div>
                        @if (!string.IsNullOrEmpty(successMessage))
                        {
                            <div class="success-banner mt-3">@successMessage</div>
                        }
                    </div>
                }
            </div>
        </div>
    }
</div>

@code {
    private string title = "";
    private int year;
    private float userRating;
    private DateTime watchedDate;
    private MovieDto? movie;
    private bool isRight;
    private string successMessage = "";

    protected override void OnInitialized()
    {
        watchedDate = DateTime.Today;
    }

    private async Task HandleSearchMovie()
    {
        isRight = false;
        successMessage = "";
        movie = await MovieApiService.SearchTmdb(title, year);
    }

    private void HandleNo()
    {
        movie = null;
        isRight = false;
    }

    private async Task HandleSaveMovie()
    {
        var result = await MovieApiService.AddMovie(new AddMovieDto
        {
            Title = title,
            Year = year,
            UserRating = userRating,
            WatchedDate = watchedDate
        });
        if (result)
        {
            successMessage = "Filmen har sparats!";
            StateHasChanged();
            await Task.Delay(2000);
            NavigationManager.NavigateTo("/add", forceLoad: true);
        }
    }
}
