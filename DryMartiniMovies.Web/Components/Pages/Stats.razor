@using DryMartiniMovies.Core.Enums
@page "/stats"
@rendermode InteractiveServer
@using DryMartiniMovies.Client.Services;
@inject MovieApiService MovieApiService

<h1>Min filmstatistik 🍸</h1>
<ErrorMessage Message="@errorMessage" />

@if (stats == null && errorMessage == null)
{
    <div class="d-flex align-items-center gap-3">
        <div class="spinner-border text-primary" role="status"></div>
        <p class="mb-0">Laddar statistik...</p>
    </div>
}
else if (stats != null)
{
    <div class="stats-container">
        <div class="stat-cards-row">
            <div class="stat-card">
                <h2>@stats.TotalMovies</h2>
                <p>sedda filmer</p>
            </div>

            <div class="stat-card">
                <h2>@stats.AverageRating.ToString("0.00")</h2>
                <p>genomsnittsbetyg</p>
            </div>

            <div class="person-cards-group">
                @if (topDirector != null)
                {
                    <div class="stat-card person-card">
                        <p class="person-label">#1 regissör</p>
                        <h2>@topDirector.Name</h2>
                        <p class="person-score">Score: @topDirector.Score.ToString("0.00")</p>
                        <p class="person-movies">@string.Join(", ", topDirector.MovieTitles)</p>
                    </div>
                }

                @if (topActor != null)
                {
                    <div class="stat-card person-card">
                        <p class="person-label">#1 skådis</p>
                        <h2>@topActor.Name</h2>
                        <p class="person-score">Score: @topActor.Score.ToString("0.00")</p>
                        <p class="person-movies">@string.Join(", ", topActor.MovieTitles)</p>
                    </div>
                }
            </div>
        </div>

        <div class="stats-section">
            <h3>Favoritgenres</h3>
            <div class="table-responsive">
            <table class="table">
                <thead>
                    <tr>
                        <th>Genre</th>
                        <th>Antal</th>
                        <th>Snittbetyg</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var genre in stats.TopGenres)
                    {
                        <tr>
                            <td>@genre.Name</td>
                            <td>@genre.Count</td>
                            <td>@genre.AverageRating.ToString("0.00")</td>
                        </tr>
                    }
                </tbody>
            </table>
            </div>
        </div>

        <div class="stats-section">
            <div class="d-flex align-items-center gap-3 mb-2" style="flex-wrap: wrap;">
            <h3 class="mb-0">Favoritregissörer</h3>
                    <select class="form-select" style="max-width: 150px" @bind="directorLimit">
                        <option value="10">Visa 10</option>
                        <option value="25">Visa 25</option>
                        <option value="50">Visa 50</option>
                        <option value="999">Visa alla</option>
                    </select>
                    <select class="form-select" style="max-width: 180px" @bind="directorSort">
                        <option value="count">Sortera på antal</option>
                        <option value="rating">Sortera på betyg</option>
                    </select>
            </div>
            <div class="table-responsive">
            <table class="table">
                <thead>
                    <tr>
                        <th>Regissör</th>
                        <th>Antal filmer</th>
                        <th>Snittbetyg</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var director in stats.TopDirectors
                        .OrderByDescending(d => directorSort == "rating" ? d.AverageRating : d.Count)
                        .Take(directorLimit))
                    {
                        <tr>
                            <td>@director.Name</td>
                            <td>@director.Count</td>
                            <td>@director.AverageRating.ToString("0.00")</td>
                        </tr>
                    }
                </tbody>
            </table>
            </div>
        </div>

        <div class="stats-section">
            <h3>Betygsdistribution</h3>
            <div class="table-responsive">
            <table class="table">
                <thead>
                    <tr>
                        <th>Betyg</th>
                        <th>Antal filmer</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var rating in stats.RatingDistribution)
                    {
                        <tr>
                            <td>⭐ @rating.Rating</td>
                            <td>@rating.Count</td>
                        </tr>
                    }
                </tbody>
            </table>
            </div>
        </div>

        <div class="stats-section">
            <h3>Filmer per decennium</h3>
            <div class="table-responsive">
            <table class="table">
                <thead>
                    <tr>
                        <th>Decennium</th>
                        <th>Antal filmer</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var decade in stats.MoviesByDecade)
                    {
                        <tr>
                            <td>@decade.Decade-talet</td>
                            <td>@decade.Count</td>
                        </tr>
                    }
                </tbody>
            </table>
            </div>
        </div>
        <div class="stats-section">
            <div class="d-flex align-items-center gap-3 mb-2" style="flex-wrap: wrap;">
            <h3 class="mb-0">Favoritskådespelare</h3>
                <select class="form-select" style="max-width: 150px" @bind="actorLimit">
                    <option value="10">Visa 10</option>
                    <option value="25">Visa 25</option>
                    <option value="50">Visa 50</option>
                    <option value="999">Visa alla</option>
                </select>
                <select class="form-select" style="max-width: 180px" @bind="actorSort">
                        <option value="count">Sortera på antal</option>
                        <option value="rating">Sortera på betyg</option>
                </select>
            </div>
            <div class="table-responsive">
            <table class="table">
                <thead>
                    <tr>
                        <th>Skådespelare</th>
                        <th>Antal filmer</th>
                        <th>Snittbetyg</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var actor in stats.TopActors.OrderByDescending(a => actorSort == "rating" ? a.AverageRating : a.Count).Take(actorLimit))
                    {
                        <tr>
                            <td>@actor.Name</td>
                            <td>@actor.Count</td>
                            <td>@actor.AverageRating.ToString("0.00")</td>
                        </tr>
                    }
                </tbody>
            </table>
            </div>
        </div>
    </div>
}

<style>
    .stats-container {
        padding: 1rem 0;
    }

    .stat-cards-row {
        display: flex;
        flex-wrap: wrap;
        gap: 1rem;
        align-items: flex-start;
    }

    .stat-cards-row .stat-card {
        margin: 0;
    }

    .person-card {
        align-items: flex-start;
        text-align: left;
        max-width: 240px;
    }

    .person-cards-group {
        display: flex;
        gap: 1rem;
        flex-wrap: wrap;
        margin-left: auto;
    }

    .person-card h2 {
        font-size: 1.4rem;
        margin-bottom: 0.25rem;
    }

    .person-label {
        font-size: 0.75rem;
        opacity: 0.55;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        margin-bottom: 0.25rem !important;
    }

    .person-score {
        font-size: 0.9rem;
        color: #ccc !important;
        margin-bottom: 0.25rem !important;
    }

    .person-movies {
        font-size: 0.78rem;
        opacity: 0.55;
        margin: 0 !important;
        line-height: 1.4;
    }

    .stats-section {
        margin-top: 2rem;
    }
</style>

@code {
    private StatsDto? stats;
    private List<PersonScoreDto> personScoreList;
    private string? errorMessage;
    private int directorLimit = 10;
    private string directorSort = "count";
    private int actorLimit = 10;
    private string actorSort = "count";
    private PersonScoreDto? topDirector => personScoreList?.FirstOrDefault(p => p.Role == PersonRole.Director);
    private PersonScoreDto? topActor => personScoreList?.FirstOrDefault(p => p.Role == PersonRole.Actor);

    protected override async Task OnInitializedAsync()
    {
        try
        {
            stats = await MovieApiService.GetStatsAsync();
            personScoreList = await MovieApiService.GetConnectorsAsync();
        }
        catch (Exception)
        {
            errorMessage = "Kunde inte hämta statistik. Kolla så API:et är igång.";
        }
    }
}