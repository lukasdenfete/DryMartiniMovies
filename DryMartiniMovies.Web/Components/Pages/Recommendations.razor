@page "/recommendations"
@rendermode InteractiveServer
@inject MovieApiService MovieApiService
@inject NavigationManager Navigation

<h1>Rekommendationer 🎬</h1>
<ErrorMessage Message="@errorMessage" />

<div class="d-flex align-items-center gap-3 mb-4">
    <span>Jag vill ha rekommendationer baserat på:</span>
    <select class="form-select w-auto" @onchange="HandleDropdownChange">
        <option value="directors">Regissörer</option>
        <option value="actors">Skådespelare</option>
        <option value="genres">Genres</option>
    </select>
    <button class="btn btn-secondary btn-sm" @onclick="RefreshRecommendations" disabled="@isLoading">
        Hämta nya rekommendationer
    </button>
</div>

@if (isLoading)
{
    <div class="d-flex align-items-center gap-3">
        <div class="spinner-border text-primary" role="status"></div>
        <p class="mb-0">Hämtar rekommendationer...</p>
    </div>
}
else
{
    <div class="movie-grid">
        @foreach (var rec in currentRecommendations)
        {
            <div class="movie-card" @onclick="() => NavigateToMovie(rec.Movie.TmdbId)">
                <img src="@($"https://image.tmdb.org/t/p/w200{rec.Movie.PosterPath}")"
                     alt="@rec.Movie.Title" />
                <div class="movie-info">
                    <h6>@rec.Movie.Title</h6>
                    <small>@rec.Movie.Year</small>
                    <div class="rating">⭐ @rec.Movie.TmdbRating.ToString("0.0") / 10</div>
                    <div class="explanation">@rec.Explanation</div>
                </div>
            </div>
        }
    </div>
}

<style>
    .movie-grid {
        display: grid;
        grid-template-columns: repeat(5, 1fr);
        gap: 1rem;
        padding: 1rem 0;
    }

    .movie-card {
        background: #1a1a2e;
        border-radius: 8px;
        overflow: hidden;
        transition: transform 0.2s;
        cursor: pointer;
    }

        .movie-card:hover {
            transform: scale(1.03);
        }

        .movie-card img {
            width: 100%;
            display: block;
        }

    .movie-info {
        padding: 0.5rem;
        color: white;
    }

        .movie-info h6 {
            margin: 0 0 0.25rem 0;
            font-size: 0.85rem;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .movie-info small {
            color: #aaa;
        }

    .rating {
        font-size: 0.8rem;
        margin-top: 0.25rem;
    }

    .explanation {
        font-size: 0.75rem;
        color: #ccc;
        margin-top: 0.25rem;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }
</style>

@code {
    private string activeTab = "directors";
    private bool isLoading = false;
    private string? errorMessage;

    private List<RecommendationDto> directorsRecs = new();
    private List<RecommendationDto> actorsRecs = new();
    private List<RecommendationDto> genresRecs = new();

    private List<RecommendationDto> currentRecommendations => activeTab switch
    {
        "directors" => directorsRecs,
        "actors" => actorsRecs,
        "genres" => genresRecs,
        _ => new()
    };

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await LoadTab("directors");
            StateHasChanged();
        }
    }

    private async Task HandleDropdownChange(ChangeEventArgs e)
    {
        var selected = e.Value?.ToString() ?? "directors";
        activeTab = selected;
        await LoadTab(selected);
    }

    private async Task LoadTab(string tab)
    {
        var alreadyLoaded = tab switch
        {
            "directors" => directorsRecs.Any(),
            "actors" => actorsRecs.Any(),
            "genres" => genresRecs.Any(),
            _ => false
        };

        if (alreadyLoaded) return;

        isLoading = true;
        errorMessage = null;
        StateHasChanged();

        try
        {
            switch (tab)
            {
                case "directors":
                    directorsRecs = await MovieApiService.GetRecommendationsByDirectorsAsync();
                    break;
                case "actors":
                    actorsRecs = await MovieApiService.GetRecommendationsByActorsAsync();
                    break;
                case "genres":
                    genresRecs = await MovieApiService.GetRecommendationsByGenresAsync();
                    break;
            }
        }
        catch (Exception)
        {
            errorMessage = "Kunde inte hämta rekommendationer. Kolla så API:et är igång.";
        }
        finally
        {
            isLoading = false;
        }
    }

    private void NavigateToMovie(int tmdbId)
    {
        Navigation.NavigateTo($"/movies/{tmdbId}");
    }
    private async Task RefreshRecommendations()
    {
        switch (activeTab)
        {
            case "directors": directorsRecs = new(); break;
            case "actors": actorsRecs = new(); break;
            case "genres": genresRecs = new(); break;
        }
        await LoadTab(activeTab);
    }
}