@page "/recommendations"
@rendermode InteractiveServer
@inject MovieApiService MovieApiService
@inject NavigationManager Navigation

<h1>Rekommendationer 🎬</h1>
<ErrorMessage Message="@errorMessage" />

<div class="d-flex align-items-center gap-3 mb-4" style="flex-wrap: wrap;">
    <span>Jag vill ha rekommendationer baserat på:</span>
    <select class="form-select w-auto" @onchange="HandleDropdownChange">
        <option value="directors">Regissörer</option>
        <option value="actors">Skådespelare</option>
        <option value="genres">Genres</option>
    </select>
    <button class="btn btn-secondary btn-sm" @onclick="NextPage" disabled="@isLoading">
        @(hasMore ? "Visa fler" : "Hämta nya rekommendationer")
    </button>
</div>

@if (isLoading)
{
    <div class="d-flex align-items-center gap-3">
        <div class="spinner-border text-primary" role="status"></div>
        <p class="mb-0">Hämtar rekommendationer...</p>
    </div>
}
else
{
    <div class="movie-grid">
        @foreach (var rec in currentRecommendations)
        {
            <div class="movie-card" @onclick="() => NavigateToMovie(rec.Movie.TmdbId)">
                <img src="@($"https://image.tmdb.org/t/p/w200{rec.Movie.PosterPath}")"
                     alt="@rec.Movie.Title" />
                <div class="movie-info">
                    <h6>@rec.Movie.Title</h6>
                    <small>@rec.Movie.Year</small>
                    <div class="rating">⭐ @rec.Movie.TmdbRating.ToString("0.0") / 10</div>
                    <div class="explanation">@rec.Explanation</div>
                </div>
            </div>
        }
    </div>
}

<style>
    .movie-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
        gap: 1rem;
        padding: 1rem 0;
    }

    .movie-card {
        background: #1a1a2e;
        border-radius: 8px;
        overflow: hidden;
        transition: transform 0.2s;
        cursor: pointer;
        display: flex;
        flex-direction: column;
    }

    .movie-card:hover {
        transform: scale(1.03);
    }

    .movie-card img {
        width: 100%;
        display: block;
    }

    .movie-info {
        padding: 0.5rem;
        color: white;
        flex: 1;
        display: flex;
        flex-direction: column;
    }

    .movie-info h6 {
        margin: 0 0 0.25rem 0;
        font-size: 0.85rem;
        word-wrap: break-word;
        overflow-wrap: break-word;
    }

    .movie-info small {
        color: #aaa;
    }

    .rating {
        font-size: 0.8rem;
        margin-top: 0.25rem;
    }

    .explanation {
        font-size: 0.75rem;
        color: #ccc;
        margin-top: auto;
        padding-top: 0.25rem;
        word-wrap: break-word;
        overflow-wrap: break-word;
    }
</style>

@code {
    private const int PageSize = 10;

    private string activeTab = "directors";
    private bool isLoading = false;
    private string? errorMessage;

    private List<RecommendationDto> directorsPool = new();
    private List<RecommendationDto> actorsPool = new();
    private List<RecommendationDto> genresPool = new();

    private Dictionary<string, int> pageIndex = new() { ["directors"] = 0, ["actors"] = 0, ["genres"] = 0 };

    private List<RecommendationDto> currentPool => activeTab switch
    {
        "directors" => directorsPool,
        "actors" => actorsPool,
        "genres" => genresPool,
        _ => new()
    };

    private List<RecommendationDto> currentRecommendations =>
        currentPool.Skip(pageIndex[activeTab] * PageSize).Take(PageSize).ToList();

    private bool hasMore => (pageIndex[activeTab] + 1) * PageSize < currentPool.Count;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await LoadTab("directors");
            StateHasChanged();
        }
    }

    private async Task HandleDropdownChange(ChangeEventArgs e)
    {
        var selected = e.Value?.ToString() ?? "directors";
        activeTab = selected;
        await LoadTab(selected);
    }

    private async Task LoadTab(string tab)
    {
        var alreadyLoaded = tab switch
        {
            "directors" => directorsPool.Any(),
            "actors" => actorsPool.Any(),
            "genres" => genresPool.Any(),
            _ => false
        };

        if (alreadyLoaded) return;

        isLoading = true;
        errorMessage = null;
        StateHasChanged();

        try
        {
            switch (tab)
            {
                case "directors":
                    directorsPool = await MovieApiService.GetRecommendationsByDirectorsAsync();
                    break;
                case "actors":
                    actorsPool = await MovieApiService.GetRecommendationsByActorsAsync();
                    break;
                case "genres":
                    genresPool = await MovieApiService.GetRecommendationsByGenresAsync();
                    break;
            }
            pageIndex[tab] = 0;
        }
        catch (Exception)
        {
            errorMessage = "Kunde inte hämta rekommendationer. Kolla så API:et är igång.";
        }
        finally
        {
            isLoading = false;
        }
    }

    private void NavigateToMovie(int tmdbId)
    {
        Navigation.NavigateTo($"/movies/{tmdbId}?from=/recommendations");
    }

    private async Task NextPage()
    {
        if (hasMore)
        {
            pageIndex[activeTab]++;
        }
        else
        {
            // Poolen är slut — hämta ny från API
            switch (activeTab)
            {
                case "directors": directorsPool = new(); break;
                case "actors": actorsPool = new(); break;
                case "genres": genresPool = new(); break;
            }
            await LoadTab(activeTab);
        }
    }
}