@using System.Diagnostics.Eventing.Reader
@inject ChatApiService ChatApiService
@rendermode InteractiveServer

<div class="chat-widget">
  @if (isOpen)
  {
    <div class="chat-window">
      <div class="chat-messages">
        @foreach (var message in chatHistory)
        {
          if (message.Role == "user") {
            <div class="message user-message">
            <p>@message.Content</p>
            </div>
            }
            else 
            {
                <div class="message assistant-message">
                <p> @message.Content</p>
                </div>
            }
        }
      </div>
      <div class="chat-input">
        <input type="text" class="chat-text" @bind="input" @bind:event="oninput" placeholder="Meddelande..." @onkeydown="HandleKeyDown"/>
        <button type="button" class="chat-button"  @onclick="() => SendMessage(input)">Skicka</button>
      </div>
    </div>
  }
 <button class="chat-bubble" @onclick="ToggleChat">💬</button>
</div>

<style>
    .chat-bubble {
        background: none;
        border: none;
        font-size: 50px;
    }
    
    .chat-widget {
        position: fixed;
        bottom: 20px;
        right: 20px;
        z-index: 1000;
        display: flex;
        flex-direction: column;
        align-items: flex-end;
        font-family: 'Nunito', sans-serif;
    }
    .chat-window {
        width: 300px;
        height: 400px;
        background: #1a1a2e;
        border: 1px solid #ccc;
        border-radius: 10px;
        overflow: hidden;
    }
    .chat-messages {
        margin: 5px;
        overflow-y: auto;
        height: calc(100% - 60px);
        color: white;
        display: flex;
        flex-direction: column;
    }
    .chat-input {
        display: flex;
        width: 100%;
        padding: 0.5rem;
        gap: 0.5rem;
        justify-content: space-between;
    }
    .chat-text {
        background-color: #16213e;
        color: white;
        border: 1px solid #0f3460;
        border-radius: 10px;
    }
    .chat-button {
        border-radius: 10px;
        background-color: #0f3460;
        color: white;
    }
    .message {
        display: flex;
        border-radius: 10px;
        margin: 5px;
    }
    .user-message {
        justify-content: flex-end;
        background-color: #16213e;
        border: 1px solid black;
        align-self: flex-end;
    }
    .assistant-message {
        justify-content: flex-start;
        background-color: #0f3460;
        border: 1px solid black;
        align-self: flex-start;
    }
    p {
        margin: 5px;
    }
    .chat-messages::-webkit-scrollbar {
        width: 6px;
    }

    .chat-messages::-webkit-scrollbar-track {
        background: #1a1a2e;
    }

    .chat-messages::-webkit-scrollbar-thumb {
        background: #0f3460;
        border-radius: 3px;
    }

</style>


@code {
    private List<ChatMessageDto> chatHistory = new List<ChatMessageDto>();
    private string input = string.Empty;
    private bool isOpen;

    private async Task SendMessage(string userMessage)
        {
            var chatMessage = new ChatMessageDto {
                Role = "user",
                Content = userMessage,
                Timestamp = DateTime.Now
            };
            chatHistory.Add(chatMessage);
            input = "";
            var response = await ChatApiService.GetResponse(chatHistory);
            var chatResponse = new ChatMessageDto {
                Role = "assistant",
                Content = response,
                Timestamp = DateTime.Now
            };
            chatHistory.Add(chatResponse);

        }
     private void ToggleChat()
        {
            isOpen = !isOpen;
            Console.WriteLine($"isOpen: {isOpen}");
        }
    private async Task HandleKeyDown(KeyboardEventArgs e)
        {
            if (e.Key == "Enter")
                await SendMessage(input);
        }

}