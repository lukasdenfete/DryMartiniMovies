@using System.Diagnostics.Eventing.Reader
@inject ChatApiService ChatApiService
@inject ChatStateService ChatStateService
@rendermode InteractiveServer

<div class="chat-widget">
  @if (ChatStateService.isOpen)
  {
    <button type="button" class="clear-button"  @onclick="() => ResetChat()"><i class="bi bi-arrow-counterclockwise"></i></button>

    <div class="chat-window">
      <div class="chat-messages">
        @foreach (var message in ChatStateService.chatHistory.AsEnumerable().Reverse()) //omvänd ordning på meddelanden i listan och column-reverse på .chat-messages för att slippa köra javascript till att visa senaste meddelandet längst ner. 
        {
          if (message.Role == "user") {
            <div class="message user-message">
            <p>@message.Content</p>
            </div>
            }
            else 
            {
                <div class="message assistant-message">
                <p> @message.Content</p>
                </div>
            }
        }
      </div>
      <div class="chat-input">
        <input type="text" class="chat-text" @bind="input" @bind:event="oninput" placeholder="Meddelande..." @onkeydown="HandleKeyDown"/>
        <button type="button" class="chat-button"  @onclick="() => SendMessage(input)"><i class="bi bi-send"></i></button>
      </div>
    </div>
  }
 <button class="chat-bubble" @onclick="ToggleChat"><i class="bi bi-robot"></i></button>
</div>

<style>
    .chat-bubble {
        background: none;
        border: none;
        font-size: 50px;
        color: orangered;
    }
    
    .chat-widget {
        position: fixed;
        bottom: 20px;
        right: 20px;
        z-index: 1000;
        display: flex;
        flex-direction: column;
        align-items: flex-end;
        font-family: 'Nunito', sans-serif;
    }
    .chat-window {
        width: 300px;
        height: 400px;
        background: #1a1a2e;
        border: 1px solid #ccc;
        border-radius: 10px;
        overflow: hidden;
    }
    .chat-messages {
        margin: 5px;
        overflow-y: auto;
        height: calc(100% - 60px);
        color: white;
        display: flex;
        flex-direction: column-reverse;
        flex: 1;
    }
    .chat-input {
        display: flex;
        width: 100%;
        padding: 0.5rem;
        gap: 0.5rem;
        align-items: center;
    }
    .chat-text {
        background-color: #16213e;
        color: white;
        border: 1px solid #0f3460;
        border-radius: 10px;
        flex: 1;
        min-width: 0;
    }
    .chat-button {
    border-radius: 50%;
    background-color: #0f3460;
    color: white;
    width: 36px;
    height: 36px;
    display: flex;
    align-items: center;
    justify-content: center;
    border: none;
    flex-shrink: 0;
    transition: background 0.2s ease;
    padding: 0;
    line-height: 1;
    }

    .chat-button i {
        font-size: 14px;
        display: flex;
        align-items: center;
        justify-content: center;
}
    .chat-button:hover {
        background-color: #1a4a7a;
    }
    .clear-button {
    background: rgba(255, 255, 255, 0.12);
    border: 1px solid rgba(255, 255, 255, 0.25);
    border-radius: 50%;
    width: 32px;
    height: 32px;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    color: rgba(255, 255, 255, 0.7);
    opacity: 0.6;
    transition: opacity 0.2s ease, background 0.2s ease;
    margin-bottom: 6px;
    }
    .clear-button:hover {
        opacity: 1;
        background: rgba(255, 255, 255, 0.2);
    }
    .clear-button i {
        font-size: 14px;
    }
    .message {
        display: flex;
        border-radius: 10px;
        margin: 5px;
    }
    .user-message {
        justify-content: flex-end;
        background-color: #16213e;
        border: 1px solid black;
        align-self: flex-end;
    }
    .assistant-message {
        justify-content: flex-start;
        background-color: #0f3460;
        border: 1px solid black;
        align-self: flex-start;
    }
    p {
        margin: 5px;
        white-space: pre-line;
    }
    .chat-messages::-webkit-scrollbar {
        width: 6px;
    }

    .chat-messages::-webkit-scrollbar-track {
        background: #1a1a2e;
    }

    .chat-messages::-webkit-scrollbar-thumb {
        background: #0f3460;
        border-radius: 3px;
    }

</style>


@code {
    private string input = string.Empty;
    private async Task SendMessage(string userMessage)
    {
        var chatMessage = new ChatMessageDto {
            Role = "user",
            Content = userMessage,
            Timestamp = DateTime.Now
            };
            ChatStateService.chatHistory.Add(chatMessage);
            input = "";
            var response = await ChatApiService.GetResponse(ChatStateService.chatHistory);
            var chatResponse = new ChatMessageDto {
                Role = "assistant",
                Content = response,
                Timestamp = DateTime.Now
            };
        ChatStateService.chatHistory.Add(chatResponse);
    }
    private void ToggleChat()
    {
        ChatStateService.isOpen = !ChatStateService.isOpen;
        Console.WriteLine($"isOpen: {ChatStateService.isOpen}");
    }
    private async Task HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
            await SendMessage(input);
    }
    private void ResetChat()
    {   
        ChatStateService.ClearHistory();
        StateHasChanged();
    }

}